# Production Environment Configuration for Render
# Copy this to your Render environment variables

APP_NAME=CCS_Profiling_System
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_URL=https://your-app.onrender.com
APP_TIMEZONE=UTC

# MongoDB Configuration
# Option 1: Individual fields
DB_CONNECTION=mongodb
DB_HOST=your-cluster.mongodb.net
DB_PORT=27017
DB_DATABASE=student_profiling
DB_USERNAME=your_username
DB_PASSWORD=your_password

# Option 2: Connection String (Recommended for MongoDB Atlas)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/student_profiling?retryWrites=true&w=majority

# Session & Cache
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file

# Mail (Optional)
MAIL_MAILER=log

# Migration Controls
RUN_MIGRATIONS=true
RUN_SEED=false
